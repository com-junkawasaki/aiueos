;; The log service — exports the log/write capability other components import.
{:aiue/component :service/log
 :aiue/kind :service
 :aiue/trust :verified
 :aiue/source "log-service.clj"
 :aiue/entry "init"
 :aiue/args []
 :aiue/exports #{:log/write}
 :aiue/effects #{:storage}
 :aiue/limits {:memory-pages 8 :fuel 1000000}}
