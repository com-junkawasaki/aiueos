;; The filesystem service — exports fs/* and consumes block/* from a driver.
{:aiue/component :service/fs
 :aiue/kind :service
 :aiue/trust :verified
 :aiue/source "fs-service.clj"
 :aiue/entry "init"
 :aiue/args []
 :aiue/imports #{:block/read :block/write}
 :aiue/exports #{:fs/open :fs/read :fs/write :fs/list}
 :aiue/effects #{:storage}
 :aiue/limits {:memory-pages 32 :fuel 5000000}}
