;; The planner is an AI agent: it subscribes to "scan" and publishes "cmd".
;; As :ai-generated it is the least-trusted node, but topic IO is permitted —
;; network/secrets/persistence are not.
{:aiue/component :agent/planner
 :aiue/kind :agent
 :aiue/wasm "planner.wat"
 :aiue/entry "tick"
 :aiue/args [0]
 :aiue/imports #{:topic/subscribe :topic/publish}
 :aiue/exports #{:topic/cmd}
 :aiue/effects #{:compute}
 :aiue/limits {:memory-pages 4 :fuel 1000000}}
