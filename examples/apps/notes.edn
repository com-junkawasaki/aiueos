;; A user app. Imports only capabilities a notes app should have: a file the user
;; chose, plus logging. No network, no secrets, no ambient filesystem.
{:aiue/component :app/notes
 :aiue/kind :app
 :aiue/trust :untrusted
 :aiue/source "notes.clj"
 :aiue/entry "main"
 :aiue/args [21]
 :aiue/imports #{:fs/open :log/write}
 :aiue/exports #{:app/main}
 :aiue/effects #{:read-file :write-file}
 :aiue/limits {:memory-pages 64 :fuel 5000000}}
