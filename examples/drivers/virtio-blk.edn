;; virtio-blk driver manifest.
;;
;; The device *meaning* lives here as data (bus/ids/queues/dma) — the OS reasons
;; over it. The driver *logic* is virtio_blk.clj (safe-kotoba). The lowest layer —
;; real MMIO/DMA/IRQ — is a kernel-provided unsafe adapter and is Phase-7 work;
;; here the effects/requires seams are already declared so policy can gate DMA.
{:aiue/component :driver/virtio-blk
 :aiue/kind :driver
 :aiue/trust :untrusted
 :aiue/source "virtio_blk.clj"
 :aiue/entry "read-block"
 :aiue/args [41]

 ;; capability wiring
 :aiue/imports #{:pci/config :dma/map :irq/subscribe :mmio/map}
 :aiue/exports #{:block/read :block/write}
 :aiue/effects #{:device-io :dma :interrupt}
 :aiue/requires #{:iommu}

 ;; OS-readable device schema
 :aiue/device {:bus :pci
               :vendor "0x1af4"
               :device "0x1001"
               :queues [{:name :request :type :virtqueue :max-size 256}]
               :interrupts [{:kind :msi-x :count 1}]
               :dma {:requires-iommu true :max-segment-size 65536}}

 :aiue/limits {:memory-pages 32 :fuel 10000000}}
