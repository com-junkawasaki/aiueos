;; An actuator: subscribes to "cmd" and drives the motor. It cannot publish —
;; it does not import :topic/publish, so a publish call would trap.
{:aiue/component :driver/actuator
 :aiue/kind :driver
 :aiue/trust :untrusted
 :aiue/wasm "actuator.wat"
 :aiue/entry "tick"
 :aiue/args [0]
 :aiue/imports #{:topic/subscribe}
 :aiue/effects #{:device-io}
 :aiue/limits {:memory-pages 4 :fuel 1000000}}
