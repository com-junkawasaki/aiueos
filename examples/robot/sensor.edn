;; A sensor: reads hardware, publishes samples to the "scan" topic.
{:aiue/component :driver/sensor
 :aiue/kind :driver
 :aiue/trust :untrusted
 :aiue/wasm "sensor.wat"
 :aiue/entry "tick"
 :aiue/args [21]
 :aiue/imports #{:topic/publish}
 :aiue/exports #{:topic/scan}
 :aiue/effects #{:device-io}
 :aiue/limits {:memory-pages 4 :fuel 1000000}}
